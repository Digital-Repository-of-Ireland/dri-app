<div class="modal fade" id="dri_advanced_search_modal_id">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title">
          <%= t('dri.views.advanced_search.header') %>
        </h2>
        <button type="button" class="dri-btn-close" data-bs-dismiss="modal" aria-hidden="true" aria-label="close">
        </button>
      </div>
      <div class="modal-body">
        <%= render(Blacklight::AdvancedSearchFormComponent.new(
          url: search_catalog_url,
          classes: ['advanced'],
          params: search_state.params_for_search.except('qt'),
          response: @response
        )) %>
      </div>
    </div>
  </div>
</div>
